---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import NewsList from '../components/NewsList.astro';
import { t, pickLang, type Locale } from '../lib/i18n';
import profile from '../data/profile.json';
import { getCollection } from 'astro:content';

const locale: Locale = 'zh';
const s = t(locale);
const edu = (await getCollection('education')).sort((a, b) => b.data.period.localeCompare(a.data.period));
const exp = (await getCollection('experience')).sort((a, b) => b.data.period.localeCompare(a.data.period));
---
<BaseLayout locale={locale}>
  <Hero locale={locale} />

  <!-- Bio · readable single column -->
  <section class="page-section">
    <div class="max-w-page mx-auto px-6">
      <header class="section-header">
        <span class="section-num">01</span>
        <h2 class="section-h">{s.sections.bio}</h2>
      </header>
      <div class="bio-body">
        <p>{profile.bio[locale]}</p>
      </div>
    </div>
  </section>

  <!-- News · what's happening now -->
  <section class="page-section">
    <div class="max-w-page mx-auto px-6">
      <header class="section-header">
        <span class="section-num">02</span>
        <h2 class="section-h">{s.sections.news}</h2>
      </header>
      <NewsList locale={locale} />
    </div>
  </section>

  <!-- Education -->
  <section class="page-section">
    <div class="max-w-page mx-auto px-6">
      <header class="section-header">
        <span class="section-num">03</span>
        <h2 class="section-h">{s.sections.education}</h2>
      </header>
      <ul class="cv-list">
        {edu.map((e) => (
          <li>
            <span class="meta cv-period">{e.data.period}</span>
            <div class="cv-body">
              <div class="cv-primary">{pickLang(e.data.school, locale)}</div>
              <div class="cv-secondary">{pickLang(e.data.degree, locale)}</div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <!-- Experience -->
  <section class="page-section">
    <div class="max-w-page mx-auto px-6">
      <header class="section-header">
        <span class="section-num">04</span>
        <h2 class="section-h">{s.sections.experience}</h2>
      </header>
      <ul class="cv-list">
        {exp.map((e) => (
          <li>
            <span class="meta cv-period">{e.data.period}</span>
            <div class="cv-body">
              <div class="cv-primary">{pickLang(e.data.org, locale)}</div>
              <div class="cv-secondary">{pickLang(e.data.title, locale)}</div>
            </div>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <style>
    .page-section {
      margin-top: clamp(4rem, 7vw, 6.5rem);
    }
    .section-header {
      display: flex;
      align-items: baseline;
      gap: 1.4rem;
      padding-bottom: 1.2rem;
      margin-bottom: 2rem;
      border-bottom: 1px solid var(--c-rule);
    }
    .section-num {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.22em;
      color: var(--c-accent);
    }
    .section-h {
      font-family: var(--font-display);
      font-weight: 400;
      font-size: clamp(1.6rem, 2vw + 1rem, 2.2rem);
      line-height: 1.1;
      color: var(--c-ink);
    }

    .bio-body {
      max-width: 68ch;
    }
    .bio-body p {
      font-family: var(--font-serif);
      font-size: 1.08rem;
      line-height: 1.85;
      color: var(--c-ink-soft);
      white-space: pre-line;
    }
    .bio-body p::first-letter {
      font-family: var(--font-display);
      font-size: 3.6rem;
      line-height: 0.9;
      float: left;
      margin: 0.3rem 0.6rem 0 0;
      color: var(--c-accent);
      font-weight: 500;
    }

    .cv-list { list-style: none; padding: 0; margin: 0; }
    .cv-list li {
      display: grid;
      grid-template-columns: 12rem 1fr;
      gap: 1.5rem;
      padding: 1.1rem 0;
      border-bottom: 1px solid var(--c-rule);
    }
    @media (max-width: 640px) {
      .cv-list li { grid-template-columns: 1fr; gap: 0.4rem; }
    }
    .cv-period { color: var(--c-muted); padding-top: 0.15rem; }
    .cv-primary {
      font-family: var(--font-serif);
      font-size: 1.05rem;
      color: var(--c-ink);
    }
    .cv-secondary {
      font-family: var(--font-serif);
      font-style: italic;
      font-size: 0.95rem;
      color: var(--c-muted);
      margin-top: 0.15rem;
    }
  </style>
</BaseLayout>
