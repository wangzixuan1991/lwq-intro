---
import { type Locale } from '../lib/i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const otherLocale = locale === 'zh' ? 'en' : 'zh';
const otherLabel = locale === 'zh' ? 'EN' : '中';

// Build a base-aware language switch target. `import.meta.env.BASE_URL`
// resolves to '/' on Vercel and '/lwq-intro/' on GitHub Pages.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const raw = Astro.url.pathname;
const stripped = (base ? raw.replace(new RegExp('^' + base), '') : raw)
  .replace(/^\/en/, '') || '/';
const target = otherLocale === 'en'
  ? (stripped === '/' ? `${base}/en/` : `${base}/en${stripped}`)
  : (stripped === '/' ? `${base}/` : `${base}${stripped}`);
---
<a href={target} class="eyebrow no-underline hover:text-ink transition-colors" style="color: var(--c-muted);" aria-label="switch language">{otherLabel}</a>
