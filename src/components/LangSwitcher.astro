---
import { type Locale } from '../lib/i18n';
interface Props { locale: Locale; }
const { locale } = Astro.props;

const otherLocale = locale === 'zh' ? 'en' : 'zh';
const otherLabel = locale === 'zh' ? 'EN' : '中';

// Astro.url.pathname includes the base path "/lwq-intro" in production, but
// not in dev. Strip both base and locale prefix to get the page slug.
const raw = Astro.url.pathname;
const stripped = raw.replace(/^\/lwq-intro/, '').replace(/^\/en/, '') || '/';
const target =
  otherLocale === 'en'
    ? stripped === '/'
      ? '/lwq-intro/en/'
      : `/lwq-intro/en${stripped}`
    : stripped === '/'
      ? '/lwq-intro/'
      : `/lwq-intro${stripped}`;
---
<a href={target} class="text-sm font-medium text-ink/80 hover:text-accent no-underline" aria-label="switch language">{otherLabel}</a>
